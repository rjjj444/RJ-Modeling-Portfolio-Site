<!-- CONTACT PAGE -->
<div class="page" id="contactPage">
  <div class="campaign-page-inner">
    <div style="max-width:560px; margin: 0 auto; padding: 3rem 2rem 5rem;">
      <p style="font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:#555;margin-bottom:0.5rem;">Get in Touch</p>
      <h1 style="font-size:28px;letter-spacing:0.1em;text-transform:uppercase;color:#111;font-weight:400;margin-bottom:0.75rem;line-height:1.1;">Contact</h1>
      <p style="font-size:12px;color:#444;line-height:2;margin-bottom:2.5rem;">Available for editorial shoots, runway, brand campaigns, and collaborations. Fill out the form below or reach out directly.</p>

      <div style="display:flex;flex-direction:column;gap:1.5rem;">
        <div style="display:flex;flex-direction:column;gap:0.3rem;">
          <label style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:#555;">Name</label>
          <input type="text" id="c-name" placeholder="Your name" style="background:transparent;border:none;border-bottom:0.5px solid #ccc;padding:0.5rem 0;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:300;color:#111;outline:none;width:100%;">
        </div>
        <div style="display:flex;flex-direction:column;gap:0.3rem;">
          <label style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:#555;">Email</label>
          <input type="email" id="c-email" placeholder="your@email.com" style="background:transparent;border:none;border-bottom:0.5px solid #ccc;padding:0.5rem 0;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:300;color:#111;outline:none;width:100%;">
        </div>
        <div style="display:flex;flex-direction:column;gap:0.3rem;">
          <label style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:#555;">Project type</label>
          <input type="text" id="c-type" placeholder="Editorial, Campaign, Runway…" style="background:transparent;border:none;border-bottom:0.5px solid #ccc;padding:0.5rem 0;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:300;color:#111;outline:none;width:100%;">
        </div>
        <div style="display:flex;flex-direction:column;gap:0.3rem;">
          <label style="font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:#555;">Message</label>
          <textarea id="c-msg" placeholder="Tell me about your project…" rows="4" style="background:transparent;border:none;border-bottom:0.5px solid #ccc;padding:0.5rem 0;font-family:'Montserrat',sans-serif;font-size:12px;font-weight:300;color:#111;outline:none;width:100%;resize:none;"></textarea>
        </div>
        <div>
          <button onclick="sendContact()" style="background:#111;color:#fff;border:none;padding:0.75rem 2.5rem;font-family:'Montserrat',sans-serif;font-size:9px;letter-spacing:0.2em;text-transform:uppercase;cursor:pointer;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'">Send Message</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function sendContact() {
    var name = document.getElementById('c-name').value;
    var email = document.getElementById('c-email').value;
    var type = document.getElementById('c-type').value;
    var msg = document.getElementById('c-msg').value;
    var subject = encodeURIComponent('Portfolio Inquiry' + (type ? ' — ' + type : ''));
    var body = encodeURIComponent('Name: ' + name + '\nEmail: ' + email + '\nProject Type: ' + type + '\n\nMessage:\n' + msg);
    window.location.href = 'mailto:rj.j.newton@gmail.com?subject=' + subject + '&body=' + body;
  }
  function showContact() {
    document.getElementById('mainPage').classList.remove('active');
    document.getElementById('denimPage').classList.remove('active');
    document.getElementById('adobePage').classList.remove('active');
    document.getElementById('disneyPage').classList.remove('active');
    document.getElementById('hofPage').classList.remove('active');
    document.getElementById('contactPage').classList.add('active');
    document.getElementById('mainNavLinks').style.display = 'none';
    document.getElementById('mainNavRight').style.display = 'none';
    document.getElementById('backBtn').style.display = 'flex';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  function showMain() {
    document.getElementById('mainPage').classList.add('active');
    document.getElementById('denimPage').classList.remove('active');
    document.getElementById('adobePage').classList.remove('active');
    document.getElementById('disneyPage').classList.remove('active');
    document.getElementById('hofPage').classList.remove('active');
    document.getElementById('contactPage').classList.remove('active');
    document.getElementById('mainNavLinks').style.display = 'flex';
    document.getElementById('mainNavRight').style.display = 'flex';
    document.getElementById('backBtn').style.display = 'none';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  function showCampaign(id) {
    document.getElementById('mainPage').classList.remove('active');
    document.getElementById('denimPage').classList.remove('active');
    document.getElementById('adobePage').classList.remove('active');
    document.getElementById(id + 'Page').classList.add('active');
    document.getElementById('mainNavLinks').style.display = 'none';
    document.getElementById('mainNavRight').style.display = 'none';
    document.getElementById('backBtn').style.display = 'flex';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
