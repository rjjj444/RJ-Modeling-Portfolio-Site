      <div class="g-cell" onclick="showCampaign('adobe')"><svg class="ph-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="0.8"><rect x="3" y="3" width="18" height="18" rx="1"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg><span class="cell-label">Adobe Photoshop</span><div class="g-overlay"><span>Click to see more</span></div></div>
