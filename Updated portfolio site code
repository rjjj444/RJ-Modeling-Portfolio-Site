<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Montserrat', Helvetica, Arial, sans-serif; background: #fff; color: #222; font-weight: 300; font-size: 12px; letter-spacing: 0.08em; }

  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 1.2rem 2rem; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); border-bottom: 0.5px solid #e8e8e8; }
  .nav-center { position: absolute; left: 50%; transform: translateX(-50%); }
  .nav-logo { font-size: 13px; font-weight: 400; letter-spacing: 0.22em; text-transform: uppercase; color: #111; cursor: pointer; }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { text-decoration: none; color: #111; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; transition: color 0.2s; cursor: pointer; }
  .nav-links a:hover { color: #555; }
  .back-btn { display: none; align-items: center; gap: 0.5rem; color: #111; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer; transition: color 0.2s; }
  .back-btn:hover { color: #555; }
  .back-btn:hover svg { transform: translateX(-3px); }
  .back-btn svg { transition: transform 0.2s; }

  .page { display: none; }
  .page.active { display: block; }
  .anchor { scroll-margin-top: 64px; }

  /* HERO */
  .hero { position: relative; width: 100%; height: calc(100vh - 53px); margin-top: 53px; overflow: hidden; display: flex; align-items: flex-end; }
  .hero img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center top; }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.6) 100%); }
  .hero-text { position: relative; z-index: 2; padding: 0 2.5rem 3.5rem; width: 100%; }
  .hero-name { font-size: clamp(2.5rem, 7vw, 5.5rem); font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: #fff; line-height: 1; margin-bottom: 0.5rem; }
  .hero-sub { font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(255,255,255,0.85); }
  .scroll-hint { position: absolute; bottom: 1.5rem; right: 2.5rem; z-index: 2; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.6); }

  .section-label { text-align: center; padding: 3rem 2rem 0; font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: #111; font-weight: 400; }
  .photo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 1.5rem 4%; }
  .photo-cell { aspect-ratio: 4/5; overflow: hidden; cursor: pointer; transition: opacity 0.25s; }
  .photo-cell:hover { opacity: 0.88; }
  .photo-cell img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  .photo-cell.center img { object-position: center; }

  .stats-bar { display: flex; justify-content: center; gap: 2.5rem; padding: 1.75rem 2rem 2.5rem; border-top: 0.5px solid #ddd; border-bottom: 0.5px solid #ddd; flex-wrap: wrap; }
  .stat-item { text-align: center; }
  .stat-key { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: #444; margin-bottom: 0.3rem; }
  .stat-val { font-size: 13px; letter-spacing: 0.05em; color: #111; }

  .gallery6 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; padding: 1.5rem 4%; }
  .g-cell { aspect-ratio: 3/4; background: #e8e6e1; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 0.5rem; cursor: pointer; transition: opacity 0.25s; position: relative; overflow: hidden; }
  .g-cell img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  .g-cell:nth-child(even) { background: #dddbd6; }
  .g-cell:hover { opacity: 0.88; }
  .g-cell span.cell-label { font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: #444; position: relative; z-index: 1; }
  .g-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease; z-index: 2; }
  .g-cell:hover .g-overlay { opacity: 1; }
  .g-overlay span { font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: #fff; }

  .about-strip { max-width: 520px; margin: 0 auto; padding: 2rem 2rem 4rem; text-align: center; }
  .about-strip h2 { font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: #111; margin-bottom: 1.25rem; font-weight: 400; }
  .about-strip p { font-size: 12px; color: #444; line-height: 2; margin-bottom: 1rem; }
  .contact-link { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #111; text-decoration: none; border-bottom: 0.5px solid #111; padding-bottom: 2px; cursor: pointer; }

  /* CAMPAIGN DETAIL */
  .campaign-page-inner { padding-top: 53px; }
  .campaign-hero { padding: 3rem 8% 2.5rem; border-bottom: 0.5px solid #eee; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  .campaign-eyebrow { font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: #555; margin-bottom: 0.5rem; }
  .campaign-title { font-size: 28px; letter-spacing: 0.1em; text-transform: uppercase; color: #111; font-weight: 400; margin-bottom: 1.25rem; line-height: 1.1; }
  .campaign-desc { font-size: 12px; color: #444; line-height: 2; }
  .campaign-hero-img { aspect-ratio: 4/5; overflow: hidden; }
  .campaign-hero-img img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  .campaign-photos { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; padding: 2rem 4%; }
  .cp-cell { aspect-ratio: 3/4; overflow: hidden; }
  .cp-cell img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }

  /* HOUSE OF BALLOONS — dark treatment */
  #hobPage { background: #0d0d0d; }
  #hobPage .campaign-page-inner { background: #0d0d0d; }
  #hobPage .campaign-hero { border-bottom: 0.5px solid #2a2a2a; }
  #hobPage .campaign-eyebrow { color: #666; }
  #hobPage .campaign-title { color: #f0ece4; }
  #hobPage .campaign-desc { color: #888; }
  #hobPage .cp-cell { background: #1a1a1a; }
  #hobPage .cp-cell-placeholder { background: #1a1a1a; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 0.5rem; }
  #hobPage .role-tag { display: inline-block; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: #555; border: 0.5px solid #2e2e2e; padding: 0.3rem 0.75rem; margin-bottom: 1.25rem; }

  .ph-icon { opacity: 0.4; }
</style>
</head>
